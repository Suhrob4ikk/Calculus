# ── Скопируй этот файл в .env и заполни значения ──────────
# Файл .env НЕ загружается в GitHub (он в .gitignore)

# ─── VAPID ключи ──────────────────────────────────────────
# ПУБЛИЧНЫЙ ключ уже стоит в js/utils.js — скопируй его сюда:
VAPID_PUBLIC_KEY=BFvc73Owpo8t4uZ_F-_w8Xdt4Bh05LtAHe_4F4aaSsVuHe7_3tpiGhr2jJLabkeYD-uZMRHfIuhs0jaDZP7diR4

# ПРИВАТНЫЙ ключ: ты записал его когда генерировал VAPID-ключи.
# Если не помнишь — сгенерируй новые:
#   npx web-push generate-vapid-keys
# (затем замени VAPID_PUBLIC_KEY выше и в js/utils.js на новый публичный ключ)
VAPID_PRIVATE_KEY=СЮДА_ПРИВАТНЫЙ_КЛЮЧ

# Твой email (нужен Web Push API — просто для идентификации)
VAPID_EMAIL=mailto:your@email.com

# ─── Gmail (для email-напоминаний через send-emails.js) ───
# 1. Зайди на myaccount.google.com → Безопасность → Двухэтапная аутентификация (включи)
# 2. → Пароли приложений → Другое → назови "Calculus" → скопируй 16-значный пароль
GMAIL_USER=твой@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Supabase Service Role Key ─────────────────────────────
# Найти в: Supabase Dashboard → Project Settings → API → service_role key
# НИКОМУ НЕ ПОКАЗЫВАЙ этот ключ — он обходит Row Level Security!
SUPABASE_SERVICE_KEY=СЮДА_SERVICE_ROLE_KEY

[{"question":"Вычислите интеграл $\\int (2x+3)^5 dx$","options":["$\\frac{(2x+3)^6}{12} + C$","$\\frac{(2x+3)^6}{6} + C$","$2(2x+3)^6 + C$","$(2x+3)^6 + C$"],"correct":0,"type":"choice","explanation":"Линейная замена: $\\int(ax+b)^n dx=\\frac{(ax+b)^{n+1}}{a(n+1)}$; здесь $\\frac{(2x+3)^6}{2\\cdot 6}=\\frac{(2x+3)^6}{12}$."},{"question":"Вычислите интеграл $\\int e^{3x-2} dx$","options":["$\\frac{1}{3}e^{3x-2} + C$","$e^{3x-2} + C$","$3e^{3x-2} + C$","$\\frac{1}{2}e^{3x-2} + C$"],"correct":0,"type":"choice","explanation":"$\\int e^{ax+b}dx=\\frac{1}{a}e^{ax+b}$; делим на $3$."},{"question":"Вычислите интеграл $\\int \\sin(4x+1) dx$","options":["$-\\frac{1}{4}\\cos(4x+1) + C$","$-4\\cos(4x+1) + C$","$\\frac{1}{4}\\cos(4x+1) + C$","$-\\cos(4x+1) + C$"],"correct":0,"type":"choice","explanation":"$\\int\\sin(ax+b)dx=-\\frac{1}{a}\\cos(ax+b)$, здесь $a=4$."},{"question":"Вычислите интеграл $\\int \\frac{1}{5x-2} dx$","options":["$\\frac{1}{5}\\ln|5x-2| + C$","$5\\ln|5x-2| + C$","$\\ln|5x-2| + C$","$\\frac{1}{2}\\ln|5x-2| + C$"],"correct":0,"type":"choice","explanation":"$\\int\\frac{dx}{ax+b}=\\frac{1}{a}\\ln|ax+b|$, здесь $a=5$."},{"question":"Вычислите интеграл $\\int (3-2x)^4 dx$","options":["$-\\frac{(3-2x)^5}{10} + C$","$\\frac{(3-2x)^5}{5} + C$","$-\\frac{(3-2x)^5}{5} + C$","$(3-2x)^5 + C$"],"correct":0,"type":"choice","explanation":"Линейная замена с $a=-2$: $\\frac{(3-2x)^5}{-2\\cdot 5}=-\\frac{(3-2x)^5}{10}$."},{"question":"Вычислите интеграл $\\int \\cos(2x-\\pi) dx$","options":["$\\frac{1}{2}\\sin(2x-\\pi) + C$","$2\\sin(2x-\\pi) + C$","$-\\frac{1}{2}\\sin(2x-\\pi) + C$","$\\sin(2x-\\pi) + C$"],"correct":0,"type":"choice","explanation":"$\\int\\cos(ax+b)dx=\\frac{1}{a}\\sin(ax+b)$, здесь $a=2$."},{"question":"Вычислите интеграл $\\int \\sqrt{3x+1} dx$","options":["$\\frac{2}{9}(3x+1)^{3/2} + C$","$\\frac{2}{3}(3x+1)^{3/2} + C$","$\\frac{1}{2}(3x+1)^{3/2} + C$","$(3x+1)^{3/2} + C$"],"correct":0,"type":"choice","explanation":"$\\sqrt{3x+1}=(3x+1)^{1/2}$: $\\frac
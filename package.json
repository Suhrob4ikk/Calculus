{
  "name": "mathcore",
  "version": "1.0.0",
  "description": "Тренажёр по высшей математике",
  "author": "Suhrob",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npx serve . -p 3000",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.mathcore.app",
    "productName": "MathCore",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "manifest.json",
      "sw.js",
      "css/**",
      "js/**",
      "icons/**",
      "node_modules/mathjs/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MathCore"
    }
  },
  "dependencies": {
    "mathjs": "^15.2.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "dotenv": "^16.6.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "nodemailer": "^8.0.8",
    "web-push": "^3.6.7"
  }
}
